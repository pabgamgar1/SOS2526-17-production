{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "sos2526-17-production",
  "compatibility_date": "2026-04-30",
  "observability": {
    "enabled": true
  },
  "main": ".svelte-kit/cloudflare/_worker.js",
  "assets": {
    "directory": ".svelte-kit/cloudflare",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
