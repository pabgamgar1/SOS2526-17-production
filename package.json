{
  "name": "sos2526-17",
  "version": "0.0.8",
  "description": "Our project is going to analyse the impact of water and renewable energy on agricultural productivity in the countries",
  "homepage": "https://github.com/pabgamgar1/SOS2526-17-production#readme",
  "bugs": {
    "url": "https://github.com/pabgamgar1/SOS2526-17-production/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pabgamgar1/SOS2526-17-production.git"
  },
  "license": "GPL",
  "author": "SOS2526-17",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "prestart": "npm run build",
    "start": "node index.js",
    "build": "npm ci --prefix src/front --progress=false && npm run build --prefix src/front",
    "dev-front": "cd src/front && npm run dev -- --open",
    "test-all-apis": "npm run test-agriculture-land && npm run test-water-productivities && npm run test-renewable-energy-consumptions  --reporters cli",
    "test-agriculture-land": "newman run tests/api-FMM/test-agriculture-land.json --reporters cli",
    "test-renewable-energy-consumptions": "newman run tests/api-PGG/api-tests.json -e tests/api-PGG/api-test-env-local.json",
    "test-water-productivities": "newman run tests/api-MRG/api-tests.json -e tests/api-MRG/api-test-env-local.json",
    "test-e2e": "npx playwright test --workers=1",
    "test": "start-server-and-test start http://localhost:3000 \"npm run test-all-apis && npm run test-e2e\"",
    "test:coverage": "npx c8 --reporter=lcov npm test",
    "deploy": "wrangler deploy",
    "preview": "wrangler dev"
  },
  "dependencies": {
    "body-parser": "^2.2.2",
    "cool-ascii-faces": "^1.3.4",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "highcharts": "^12.6.0",
    "nedb": "^1.8.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-node": "^5.5.4",
    "jest": "^30.3.0",
    "newman": "^6.2.2",
    "start-server-and-test": "^2.1.5",
    "wrangler": "^4.86.0"
  }
}
